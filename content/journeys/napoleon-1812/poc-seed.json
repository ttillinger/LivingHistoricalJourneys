"moments": [
  {
    "time": "1812-06-24T06:00:00Z",
    "title": "Crossing the Niemen",
    "text": "Napoleon's Grande Armée begins crossing the Niemen River into Russian territory."
  },
  {
    "time": "1812-07-16T12:00:00Z",
    "title": "Heat and disease",
    "text": "Summer heat, long marches, and supply problems begin to thin the ranks before any major battle."
  },
  {
    "time": "1812-08-17T09:00:00Z",
    "title": "Smolensk in flames",
    "text": "Fighting around Smolensk leaves much of the city destroyed and costs thousands of casualties on both sides."
  },
  {
    "time": "1812-09-07T05:00:00Z",
    "title": "Battle of Borodino",
    "text": "One of the bloodiest single-day battles of the era; the French hold the field but at enormous cost."
  },
  {
    "time": "1812-09-14T16:00:00Z",
    "title": "Moscow, but no peace",
    "text": "The French enter a largely deserted Moscow. Fires soon consume much of the city and no peace offer arrives."
  },
  {
    "time": "1812-10-19T08:00:00Z",
    "title": "Retreat from Moscow",
    "text": "With winter coming and supplies exhausted, Napoleon orders the retreat westward."
  },
  {
    "time": "1812-11-09T12:00:00Z",
    "title": "Winter closes in",
    "text": "Snow, hunger, and Russian attacks turn the retreat into a desperate struggle for survival."
  },
  {
    "time": "1812-11-26T10:00:00Z",
    "title": "Crossing the Berezina",
    "text": "Improvised bridges under fire allow part of the army to escape, but losses are catastrophic."
  },
  {
    "time": "1812-12-14T08:00:00Z",
    "title": "Back over the Niemen",
    "text": "The shattered remnants of the Grande Armée recross the Niemen, ending the campaign."
  }
]
