{
  "id": "napoleon-1812",
  "version": 1,
  "title": "Napoleon's 1812 Russian Campaign",
  "description": "The Grande Armée's advance to Moscow and its catastrophic winter retreat, June–December 1812. Strength and temperature follow Minard's 1869 chart. Interim content — density and sourcing deepen in a later research pass.",
  "tier": "free",
  "coordinateSpace": "geo",
  "time": {
    "start": "1812-06-24T03:00:00Z",
    "end": "1812-12-14T12:00:00Z"
  },
  "mapDefaults": {
    "bounds": [
      20,
      52,
      40,
      58
    ],
    "styles": [
      "campaign-1812",
      "atlas",
      "modern"
    ]
  },
  "moments": [
    {
      "t": "1812-06-24T04:00:00Z",
      "title": "Crossing the Niemen",
      "body": "The Grande Armée — some 450,000 men in all — begins pouring across the Niemen into Russian territory. No enemy stands to oppose it.",
      "tags": [
        "crossing"
      ],
      "significance": 3
    },
    {
      "t": "1812-06-26T12:00:00Z",
      "title": "The Russians will not stand",
      "body": "Barclay de Tolly withdraws rather than give battle, drawing the invaders deeper into a scorched countryside.",
      "tags": [
        "maneuver"
      ],
      "significance": 1
    },
    {
      "t": "1812-06-28T18:00:00Z",
      "title": "Vilna without a fight",
      "body": "Napoleon enters Vilna. Already the roads behind him are littered with broken-down wagons and dead horses.",
      "tags": [
        "occupation"
      ],
      "significance": 2
    },
    {
      "t": "1812-07-06T12:00:00Z",
      "title": "Heat, dust, and dying horses",
      "body": "Searing heat and thunderstorms wreck the supply train. Thousands of horses die in days; men fall out by the roadside.",
      "tags": [
        "attrition"
      ],
      "significance": 2
    },
    {
      "t": "1812-07-16T12:00:00Z",
      "title": "Disease thins the ranks",
      "body": "Dysentery and typhus spread through the columns. The army is bleeding strength before it has fought a single battle.",
      "tags": [
        "attrition"
      ],
      "significance": 2
    },
    {
      "t": "1812-07-28T12:00:00Z",
      "title": "Vitebsk — the quarry slips away",
      "body": "Napoleon reaches Vitebsk hoping for a decisive battle, but the Russians are gone again. He briefly considers halting here for the winter.",
      "tags": [
        "maneuver"
      ],
      "significance": 2
    },
    {
      "t": "1812-08-13T12:00:00Z",
      "title": "The decision to press on",
      "body": "Against the advice of his marshals, Napoleon resolves to march on Smolensk and force the battle he needs.",
      "tags": [
        "politics"
      ],
      "significance": 1
    },
    {
      "t": "1812-08-17T06:00:00Z",
      "title": "Smolensk in flames",
      "body": "Two days of fighting leave the ancient city burning. The Russians slip away eastward under cover of the smoke.",
      "tags": [
        "battle"
      ],
      "significance": 3
    },
    {
      "t": "1812-08-19T10:00:00Z",
      "title": "A hollow victory",
      "body": "The French hold Smolensk's ruins but have again failed to trap the Russian army. The road east is open — and devastated.",
      "tags": [
        "battle"
      ],
      "significance": 2
    },
    {
      "t": "1812-09-05T15:00:00Z",
      "title": "The Shevardino redoubt",
      "body": "A vicious preliminary fight for an earthwork southwest of Borodino signals that the Russians mean, at last, to stand.",
      "tags": [
        "battle"
      ],
      "significance": 2
    },
    {
      "t": "1812-09-07T06:00:00Z",
      "title": "The Battle of Borodino begins",
      "body": "At dawn 250,000 men and over 1,000 guns collide on a front a few miles wide. It will be the bloodiest single day of the age.",
      "tags": [
        "battle"
      ],
      "significance": 3
    },
    {
      "t": "1812-09-07T16:00:00Z",
      "title": "The Great Redoubt falls",
      "body": "After hours of slaughter the Raevsky Redoubt is finally stormed, but the Russian line bends without breaking.",
      "tags": [
        "battle"
      ],
      "significance": 3
    },
    {
      "t": "1812-09-08T09:00:00Z",
      "title": "A field of the dead",
      "body": "Around 70,000 men are dead or wounded. The Russians withdraw in good order; Napoleon has his 'victory' but not his decisive result.",
      "tags": [
        "battle",
        "attrition"
      ],
      "significance": 3
    },
    {
      "t": "1812-09-14T16:00:00Z",
      "title": "Moscow, but no peace",
      "body": "The Grande Armée enters a Moscow that is silent and three-quarters empty. No delegation comes to offer terms.",
      "tags": [
        "occupation"
      ],
      "significance": 3
    },
    {
      "t": "1812-09-15T22:00:00Z",
      "title": "Moscow burns",
      "body": "Fires break out across the city and spread through the night, consuming the shelter and supplies the army had counted on.",
      "tags": [
        "occupation"
      ],
      "significance": 3
    },
    {
      "t": "1812-09-20T12:00:00Z",
      "title": "Waiting in the ashes",
      "body": "Napoleon lingers among the ruins, sending peace feelers to a Tsar who will not answer, while the season turns against him.",
      "tags": [
        "occupation",
        "politics"
      ],
      "significance": 2
    },
    {
      "t": "1812-10-13T08:00:00Z",
      "title": "First snow",
      "body": "Light snow flurries fall on Moscow — a warning of the winter that everyone but the Emperor seems to feel coming.",
      "tags": [
        "winter"
      ],
      "significance": 2
    },
    {
      "t": "1812-10-19T08:00:00Z",
      "title": "The retreat begins",
      "body": "With no peace and no supplies, Napoleon abandons Moscow and marches southwest, hoping for an untouched road home.",
      "tags": [
        "retreat"
      ],
      "significance": 3
    },
    {
      "t": "1812-10-24T10:00:00Z",
      "title": "Turned back at Maloyaroslavets",
      "body": "Kutuzov blocks the southern road in a savage fight. The Grande Armée is forced back onto the ruined Smolensk highway.",
      "tags": [
        "battle",
        "retreat"
      ],
      "significance": 3
    },
    {
      "t": "1812-10-28T12:00:00Z",
      "title": "The road of bones",
      "body": "The army retraces the devastated route past the unburied dead of Borodino. Starvation and cold begin in earnest.",
      "tags": [
        "retreat",
        "attrition"
      ],
      "significance": 2
    },
    {
      "t": "1812-11-03T12:00:00Z",
      "title": "Rearguard mauled at Vyazma",
      "body": "Russian forces fall on the strung-out columns; discipline in several corps begins to dissolve.",
      "tags": [
        "battle",
        "retreat"
      ],
      "significance": 2
    },
    {
      "t": "1812-11-06T12:00:00Z",
      "title": "The first hard frost",
      "body": "The temperature plunges. Ill-shod men freeze where they fall; horses die and are butchered on the spot.",
      "tags": [
        "winter",
        "attrition"
      ],
      "significance": 2
    },
    {
      "t": "1812-11-09T12:00:00Z",
      "title": "Smolensk offers no salvation",
      "body": "The magazines at Smolensk are found nearly bare and are quickly plundered. There is no rest and little food here.",
      "tags": [
        "retreat"
      ],
      "significance": 2
    },
    {
      "t": "1812-11-14T08:00:00Z",
      "title": "The army disintegrates",
      "body": "Leaving Smolensk in scattered groups, the Grande Armée is becoming a mob of stragglers around a shrinking core of fighting men.",
      "tags": [
        "retreat",
        "attrition"
      ],
      "significance": 2
    },
    {
      "t": "1812-11-16T12:00:00Z",
      "title": "Cut to pieces at Krasny",
      "body": "Ney's rearguard is nearly annihilated and fights its way out across the ice. Thousands are killed or captured.",
      "tags": [
        "battle",
        "retreat"
      ],
      "significance": 3
    },
    {
      "t": "1812-11-19T12:00:00Z",
      "title": "Burning the eagles at Orsha",
      "body": "Cannon are spiked and standards burned to keep them from Russian hands. What remains crosses the Dnieper.",
      "tags": [
        "retreat"
      ],
      "significance": 1
    },
    {
      "t": "1812-11-22T12:00:00Z",
      "title": "The bridges are lost",
      "body": "The Russians seize the crossings at Borisov. For a moment the whole army seems trapped against the Berezina.",
      "tags": [
        "retreat"
      ],
      "significance": 2
    },
    {
      "t": "1812-11-26T08:00:00Z",
      "title": "Crossing the Berezina",
      "body": "Engineers build two trestle bridges at Studenka, standing in the freezing river. The remnant army begins to cross.",
      "tags": [
        "crossing"
      ],
      "significance": 3
    },
    {
      "t": "1812-11-28T14:00:00Z",
      "title": "Carnage at the bridges",
      "body": "Russian guns rake both banks. Amid panic among the stragglers, thousands drown or are trampled at the crossings.",
      "tags": [
        "battle",
        "crossing"
      ],
      "significance": 3
    },
    {
      "t": "1812-11-29T10:00:00Z",
      "title": "The bridges are burned",
      "body": "To stop the pursuit, the bridges are fired with thousands still on the east bank. Their cries carry across the river.",
      "tags": [
        "crossing",
        "attrition"
      ],
      "significance": 3
    },
    {
      "t": "1812-12-05T20:00:00Z",
      "title": "The Emperor departs",
      "body": "At Smorgon, Napoleon hands over command and races ahead by sleigh to Paris to raise a new army.",
      "tags": [
        "politics"
      ],
      "significance": 3
    },
    {
      "t": "1812-12-06T06:00:00Z",
      "title": "The coldest night",
      "body": "The thermometer falls toward −37°C. Men freeze around dying campfires; whole units simply cease to exist by morning.",
      "tags": [
        "winter",
        "attrition"
      ],
      "significance": 2
    },
    {
      "t": "1812-12-08T12:00:00Z",
      "title": "A ghost army reaches Vilna",
      "body": "A few thousand skeletal survivors stumble into Vilna, only to be driven on again as the Russians close in.",
      "tags": [
        "retreat"
      ],
      "significance": 2
    },
    {
      "t": "1812-12-14T08:00:00Z",
      "title": "Back over the Niemen",
      "body": "Of the host that crossed in June, perhaps ten thousand recross as a formed body. The campaign is over; the myth of invincibility is broken.",
      "tags": [
        "crossing"
      ],
      "significance": 3
    }
  ],
