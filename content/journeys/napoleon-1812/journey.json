      "end": "1812-09-07T20:00:00Z",
      "kind": "battle",
      "title": "Battle of Borodino",
      "narrativeBeats": [
        {
          "t": "1812-09-07T05:30:00Z",
          "text": "Dawn: the French grand battery opens fire across the Kolocha."
        },
        {
          "t": "1812-09-07T09:00:00Z",
          "text": "The Bagration flèches change hands again and again in the smoke."
        },
        {
          "t": "1812-09-07T13:00:00Z",
          "text": "The Raevsky Redoubt — the Great Redoubt — is stormed at last."
        },
        {
          "t": "1812-09-07T18:00:00Z",
          "text": "Nightfall: the Russians hold their ground, then withdraw. The field is a charnel house."
        }
      ]
    },
    {
      "id": "moscow-occupation",
      "start": "1812-09-14T12:00:00Z",
      "end": "1812-10-19T06:00:00Z",
      "kind": "encampment",
      "title": "The Occupation of Moscow",
      "narrativeBeats": [
        {
          "t": "1812-09-14T16:00:00Z",
          "text": "The army enters a silent, half-abandoned city."
        },
        {
          "t": "1812-09-15T22:00:00Z",
          "text": "Fires break out and race through the wooden streets."
        },
        {
          "t": "1812-09-18T12:00:00Z",
          "text": "Three-quarters of Moscow lies in ashes."
        },
        {
          "t": "1812-10-05T12:00:00Z",
          "text": "A last peace overture is sent to the Tsar. No answer comes."
        }
      ]
    },
    {
      "id": "maloyaroslavets",
      "start": "1812-10-24T06:00:00Z",
      "end": "1812-10-24T21:00:00Z",
      "kind": "battle",
      "title": "Battle of Maloyaroslavets"
    },
    {
      "id": "krasny",
      "start": "1812-11-15T00:00:00Z",
      "end": "1812-11-18T23:00:00Z",
      "kind": "battle",
      "title": "Battle of Krasny"
    },
    {
      "id": "berezina",
      "start": "1812-11-26T00:00:00Z",
      "end": "1812-11-29T12:00:00Z",
      "kind": "crossing",
      "title": "Crossing of the Berezina",
      "narrativeBeats": [
        {
          "t": "1812-11-26T06:00:00Z",
          "text": "Pontooniers build two trestle bridges at Studenka in the freezing current."
        },
        {
          "t": "1812-11-27T10:00:00Z",
          "text": "The Guard and remaining fighting units cross to the west bank."
        },
        {
          "t": "1812-11-28T14:00:00Z",
          "text": "Russian batteries open on both banks; panic seizes the mass of stragglers."
        },
        {
          "t": "1812-11-29T09:00:00Z",
          "text": "The bridges are burned with thousands still stranded on the east bank."
        }
      ]
    },
    {
